{
  "manifest_version": 3,
  "name": "AI-upload-pdf",
  "version": "1.0.0",
  "description": "Receive one-time bridge tasks from Zotero and automate Web AI pages in Chrome.",
  "permissions": ["debugger", "tabs", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1/*", "https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "AI-upload-pdf",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
